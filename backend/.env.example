# Backend service configuration (indexer + REST API).
# Copy to ".env" and adjust.

# Deployed Payments contract id (output of scripts/deploy.sh).
CONTRACT_ID=

# Network: futurenet (default) or testnet.
BACKEND_NETWORK=futurenet

# Optional RPC URL override.
# RPC_URL=

# REST API port.
PORT=3000

# Indexer polling interval (ms).
POLL_INTERVAL_MS=15000

# How many payment ids to scan per poll batch.
BATCH_SIZE=50

# Optional API key required for write endpoints (empty = open).
# API_KEY=

# CORS allowed origins (comma separated, empty = allow all).
# CORS_ORIGINS=https://myapp.com

# SQLite file path.
DB_FILE=data/smartage.db

# Max requests per 15-min window per IP (0 = disabled).
RATE_LIMIT=100
