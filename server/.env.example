# SmartAge unified server config.
# Copy to server/.env and fill in.

# Deployed Payments contract id (output of scripts/deploy.sh).
CONTRACT_ID=

# Network: futurenet (default) or testnet.
BACKEND_NETWORK=futurenet

# REST API port (default 3001).
PORT=3001

# Indexer polling interval (ms, default 15000).
POLL_INTERVAL_MS=15000

# How many payment ids to scan per poll batch (default 50).
BATCH_SIZE=50

# SQLite file path (default server/data/smartage.db).
DB_FILE=server/data/smartage.db

# Path to built frontend dist directory (auto-detected if running from repo root).
# FRONTEND_DIR=../frontend/dist

# Max requests per 15-min window per IP (0 = disabled, default 100).
RATE_LIMIT=100
